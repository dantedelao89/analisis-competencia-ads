# Llaves necesarias para usar la skill.
# Copiá este archivo a `.env` y reemplazá con TUS llaves.
# Claude te puede guiar a sacarlas si abrís el proyecto y pegás un link de Facebook.

# Apify — sacalo en: https://console.apify.com/settings/integrations
APIFY_TOKEN=apify_api_pega_tu_token_aqui

# Google Gemini — sacalo en: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza_pega_tu_api_key_aqui
